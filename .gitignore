__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.venv/
.env

# Generated artifacts. Real data must never be committed; synthetic samples are
# regenerated by `python -m src.main generate-synthetic` so we don't ship them.
output/
samples/synthetic/

# operator_pilot/ is the in-repo learn-only drop-zone (see
# operator_pilot/README.zh-CN.md). The two subdirectories must mask every
# real input and every generated learn-mode artifact; the .gitkeep markers
# (and README.zh-CN.md / PROMPT_FOR_AGENT.md one level above) stay tracked.
# `output/` above is unanchored and would otherwise pull in
# `operator_pilot/output/` as a directory exclusion — re-include the
# directory explicitly so the file-level negation below works.
!operator_pilot/output/
operator_pilot/input/*
!operator_pilot/input/.gitkeep
operator_pilot/output/*
!operator_pilot/output/.gitkeep
